        <locationX>710</locationX>
        <locationY>539</locationY>
        <assignmentItems>
            <assignToReference>$Record.Resolved_At__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>nullDateTime</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <recordUpdates>
        <name>Update_Request_Due_By</name>
        <label>Update Request Due By</label>
        <locationX>182</locationX>
        <locationY>539</locationY>
        <inputAssignments>
            <field>Due_By__c</field>
            <value>
                <elementReference>formulaDueBy</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <variables>
        <name>nullDateTime</name>
        <dataType>DateTime</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <start>
        <locationX>56</locationX>
