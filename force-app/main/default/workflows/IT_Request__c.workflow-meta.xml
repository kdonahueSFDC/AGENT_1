<?xml version="1.0" encoding="UTF-8" ?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>IT_Request_Confirmation_Alert</fullName>
        <description
    >Sends confirmation email to employee when IT request is created</description>
        <protected>false</protected>
        <recipients>
            <field>Employee_Email__c</field>
            <type>email</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>IT_Requests/IT_Request_Confirmation</template>
    </alerts>
    <alerts>
        <fullName>IT_Request_Escalation_Alert</fullName>
        <description
    >Notifies IT Tier 2 Queue when request is escalated</description>
        <protected>false</protected>
        <recipients>
            <type>group</type>
            <recipient>IT_Tier_2_Queue</recipient>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>IT_Requests/IT_Request_Escalation_Notification</template>
    </alerts>
    <alerts>
        <fullName>IT_Request_SLA_Breach_Alert</fullName>
        <description
    >Alerts IT Tier 2 Queue when SLA deadline is breached</description>
        <protected>false</protected>
        <recipients>
            <type>group</type>
            <recipient>IT_Tier_2_Queue</recipient>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>IT_Requests/IT_Request_SLA_Breach</template>
    </alerts>
</Workflow>
