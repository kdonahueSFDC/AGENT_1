<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Grants CRUD + FLS on IT_Request__c and access to the three IT Help Desk invocable Apex classes. Assigned to both the Agentforce Agent User and the admin so the object is visible at runtime.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>IT Help Desk Agent Access</label>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>IT_Request__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>IT_Request__c.Employee_Name__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>IT_Request__c.Issue_Description__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>IT_Request__c.Priority__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>IT_Request__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>IT_Request__c.Assigned_Tier__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <classAccesses>
        <apexClass>CreateITRequest</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>GetRequestStatus</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>EscalateRequest</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
